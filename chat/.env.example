# Copie para chat/.env e preencha. O .env NÃO é commitado (ver .gitignore)
# Cada chave só é necessária para os modelos do respectivo provedor.

# OpenAI (modelos gpt-5.4, gpt-5.4-mini)
OPENAI_API_KEY=

# Azure OpenAI (modelos azure-gpt-5.4, azure-gpt-5.4-mini)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=           # ex: https://meu-recurso.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01

ANTHROPIC_API_KEY=

# Opcional, mas recomendado: chave da NCBI E-utilities (sobe o limite de
# 3→10 req/s e reduz erros 429 na busca da PubMed). https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=
NCBI_EMAIL=